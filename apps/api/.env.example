# TripFlow API Environment Variables
# Copy this file to .env and fill in the values

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: required only for legacy HS256 JWT projects.
# For newer Supabase projects using asymmetric keys (JWKS / RS256), leave empty.
SUPABASE_JWT_SECRET=

# API
API_CORS_ORIGINS=["http://localhost:3000"]

# Email backend: "gmail" (default) or "resend"
# TODO: Switch to EMAIL_BACKEND=resend once a domain is verified at resend.com/domains
EMAIL_BACKEND=gmail

# Gmail SMTP — used when EMAIL_BACKEND=gmail
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords and create an App Password
# 3. Fill in the 16-character password below (no spaces)
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Resend — used when EMAIL_BACKEND=resend (requires verified domain)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here
# Use onboarding@resend.dev for testing without a verified domain.
# Change to noreply@yourdomain.com once your domain is verified in Resend.
EMAIL_FROM=onboarding@resend.dev
