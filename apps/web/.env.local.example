# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — server only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Share invites
WEB_BASE_URL=http://localhost:3000
SHARE_INVITE_TTL_HOURS=48

# Session timeout configuration (seconds)
NEXT_PUBLIC_SESSION_TIMEOUT_DURATION=1200
NEXT_PUBLIC_SESSION_TIMEOUT_WARNING=120

# Travel plan configuration
NEXT_PUBLIC_MAX_TRIP_DAYS=30

# Email — Gmail SMTP (for invite emails and contact form)
# 1. Enable 2-Step Verification in your Gmail account settings
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Use your Gmail address as GMAIL_USER and the generated 16-character password as GMAIL_APP_PASSWORD
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
