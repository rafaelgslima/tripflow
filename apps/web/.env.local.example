# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — server only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Share invites
WEB_BASE_URL=http://localhost:3000
SHARE_INVITE_TTL_HOURS=48

# Session timeout configuration (seconds)
NEXT_PUBLIC_SESSION_TIMEOUT_DURATION=1200
NEXT_PUBLIC_SESSION_TIMEOUT_WARNING=120

# Travel plan configuration
NEXT_PUBLIC_MAX_TRIP_DAYS=30

# Email — SendGrid (current provider, no custom domain required)
# 1. Create a free account at https://sendgrid.com
# 2. Verify a Single Sender at https://app.sendgrid.com/settings/sender_auth/senders
# 3. Create an API key at https://app.sendgrid.com/settings/api_keys
# TODO: Replace with Resend once a custom domain is verified (see apps/web/src/lib/api-server/email.ts)
SENDGRID_API_KEY=SG.your-api-key-here
EMAIL_FROM=your-verified-email@gmail.com
