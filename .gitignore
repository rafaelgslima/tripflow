# ============================================================================
# Planutrip Monorepo .gitignore
# ============================================================================

# ============================================================================
# Environment & Secrets (NEVER COMMIT)
# ============================================================================
.env
.env.local
.env.*.local
.env.production
.env.development
*.env
.env.keys

# Supabase secrets
*service-role-key*
*anon-key*

# ============================================================================
# Operating System
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ============================================================================
# IDEs & Editors
# ============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws

# Vim
*.swp
*.swo
*~

# ============================================================================
# Node.js / Next.js (for apps/web)
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js
.next/
out/
build/
dist/

# Testing
coverage/
.nyc_output/

# Logs
logs/
*.log

# ============================================================================
# Python / FastAPI (for apps/api)
# ============================================================================
# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv/
.venv-py312/
.python-version

# Distribution / packaging
*.egg-info/
dist/
build/
eggs/
.eggs/
*.egg

# Testing / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# ============================================================================
# Supabase Local Development
# ============================================================================
# DO NOT ignore: supabase/migrations/ (these MUST be committed)
# DO NOT ignore: supabase/config.toml (should be committed)

# Ignore temporary Supabase files
supabase/.branches/
supabase/.temp/

# ============================================================================
# Docker
# ============================================================================
*.log

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.bak
*.swp
*.swo

# ============================================================================
# Build Outputs
# ============================================================================
*.tsbuildinfo
